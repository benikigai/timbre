{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd packages/shared && npm install && cd ../frontend && npm install && npm run build",
  "outputDirectory": "packages/frontend/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://eliass-mac-mini.tail365038.ts.net:8443/api/:path*"
    },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
